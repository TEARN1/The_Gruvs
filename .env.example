# Environment Variables
# Copy this file to .env and fill in actual values

# Expo/EAS Configuration (optional)
# EAS_PROJECT_ID=your_eas_project_id

# API Endpoints (if backend integration is added later)
# API_BASE_URL=https://api.example.com
# API_KEY=your_api_key_here

# Feature Flags
# FEATURE_SYNC_ENABLED=false
# FEATURE_NOTIFICATIONS_ENABLED=false

# Logging & Analytics (optional)
# SENTRY_DSN=https://your-sentry-endpoint
# ANALYTICS_ENABLED=false
